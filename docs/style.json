{
  "version": 8,
  "name": "Blank Map for Kids (白地図・子供向け)",
  "sources": {
    "geolonia": {
      "type": "vector",
      "url": "https://tileserver.geolonia.com/v2_combined2/tiles.json?key=YOUR-API-KEY"
    }
  },
  "glyphs": "https://glyphs.geolonia.com/{fontstack}/{range}.pbf",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#f9f9f9"
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "geolonia",
      "source-layer": "water",
      "paint": {
        "fill-color": "#edf5fa",
        "fill-outline-color": "#ddedf5"
      }
    },
    {
      "id": "oc-water",
      "type": "fill",
      "source": "geolonia",
      "source-layer": "oc-water",
      "paint": {
        "fill-color": "#edf5fa",
        "fill-outline-color": "#ddedf5"
      }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "geolonia",
      "source-layer": "waterway",
      "minzoom": 8,
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#ddedf5",
        "line-width": {
          "stops": [
            [
              8,
              1
            ],
            [
              14,
              3
            ]
          ]
        }
      }
    },
    {
      "id": "boundary-land-level-0",
      "type": "line",
      "source": "geolonia",
      "source-layer": "boundary",
      "filter": [
        "==",
        [
          "get",
          "admin_level"
        ],
        0
      ],
      "layout": {
        "line-join": "round",
        "line-cap": "round"
      },
      "paint": {
        "line-color": "#555555",
        "line-width": {
          "stops": [
            [
              0,
              1.5
            ],
            [
              6,
              3
            ]
          ]
        }
      }
    },
    {
      "id": "boundary-land-level-2",
      "type": "line",
      "source": "geolonia",
      "source-layer": "boundary",
      "filter": [
        "all",
        [
          "==",
          [
            "get",
            "admin_level"
          ],
          2
        ],
        [
          "==",
          [
            "has",
            "maritime"
          ],
          false
        ]
      ],
      "layout": {
        "line-join": "round",
        "line-cap": "round"
      },
      "paint": {
        "line-color": "#555555",
        "line-width": {
          "stops": [
            [
              0,
              1
            ],
            [
              6,
              2.5
            ]
          ]
        }
      }
    },
    {
      "id": "boundary-land-level-4",
      "type": "line",
      "source": "geolonia",
      "source-layer": "boundary",
      "minzoom": 4,
      "filter": [
        "all",
        [
          "==",
          [
            "get",
            "admin_level"
          ],
          4
        ],
        [
          "==",
          [
            "has",
            "maritime"
          ],
          false
        ]
      ],
      "layout": {
        "line-join": "round",
        "line-cap": "round"
      },
      "paint": {
        "line-color": "#3d5a80",
        "line-width": {
          "stops": [
            [
              4,
              0.5
            ],
            [
              7,
              1
            ],
            [
              12,
              1.5
            ]
          ]
        }
      }
    },
    {
      "id": "boundary-land-level-6",
      "type": "line",
      "source": "geolonia",
      "source-layer": "boundary",
      "minzoom": 8,
      "filter": [
        "all",
        [
          "==",
          [
            "get",
            "admin_level"
          ],
          6
        ],
        [
          "==",
          [
            "has",
            "maritime"
          ],
          false
        ]
      ],
      "layout": {
        "line-join": "round",
        "line-cap": "round"
      },
      "paint": {
        "line-color": "#7a9bb5",
        "line-dasharray": [
          3,
          2
        ],
        "line-width": {
          "stops": [
            [
              8,
              1.2
            ],
            [
              12,
              2
            ]
          ]
        }
      }
    },
    {
      "id": "place-country",
      "type": "symbol",
      "source": "geolonia",
      "source-layer": "place",
      "maxzoom": 12,
      "filter": [
        "==",
        "class",
        "country"
      ],
      "layout": {
        "text-font": [
          "Noto Sans Bold"
        ],
        "text-field": "{name}",
        "text-size": {
          "stops": [
            [
              1,
              14
            ],
            [
              4,
              20
            ]
          ]
        },
        "text-max-width": 6,
        "text-letter-spacing": 0.1,
        "symbol-sort-key": [
          "case",
          [
            "in",
            [
              "get",
              "name"
            ],
            [
              "literal",
              [
                "日本",
                "Japan"
              ]
            ]
          ],
          0,
          [
            "coalesce",
            [
              "get",
              "rank"
            ],
            100
          ]
        ]
      },
      "paint": {
        "text-color": "#444444",
        "text-halo-color": "#ffffff",
        "text-halo-width": 2
      }
    },
    {
      "id": "place-state",
      "type": "symbol",
      "source": "geolonia",
      "source-layer": "place",
      "minzoom": 4,
      "maxzoom": 12,
      "filter": [
        "==",
        "class",
        "state"
      ],
      "layout": {
        "text-font": [
          "Noto Sans Bold"
        ],
        "text-field": "{name}",
        "text-size": {
          "stops": [
            [
              4,
              13
            ],
            [
              8,
              18
            ]
          ]
        },
        "text-max-width": 6,
        "text-letter-spacing": 0.05
      },
      "paint": {
        "text-color": "#555555",
        "text-halo-color": "#ffffff",
        "text-halo-width": 2
      }
    },
    {
      "id": "place-city",
      "type": "symbol",
      "source": "geolonia",
      "source-layer": "place",
      "minzoom": 6,
      "maxzoom": 16,
      "filter": [
        "==",
        "class",
        "city"
      ],
      "layout": {
        "text-font": [
          "Noto Sans Bold"
        ],
        "text-field": "{name}",
        "text-size": {
          "stops": [
            [
              6,
              13
            ],
            [
              10,
              16
            ]
          ]
        },
        "text-max-width": 6
      },
      "paint": {
        "text-color": "#555555",
        "text-halo-color": "#ffffff",
        "text-halo-width": 2
      }
    },
    {
      "id": "place-town",
      "type": "symbol",
      "source": "geolonia",
      "source-layer": "place",
      "minzoom": 9,
      "maxzoom": 16,
      "filter": [
        "==",
        "class",
        "town"
      ],
      "layout": {
        "text-font": [
          "Noto Sans Regular"
        ],
        "text-field": "{name}",
        "text-size": {
          "stops": [
            [
              9,
              12
            ],
            [
              13,
              15
            ]
          ]
        },
        "text-max-width": 6
      },
      "paint": {
        "text-color": "#666666",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "place-village",
      "type": "symbol",
      "source": "geolonia",
      "source-layer": "place",
      "minzoom": 11,
      "maxzoom": 16,
      "filter": [
        "==",
        "class",
        "village"
      ],
      "layout": {
        "text-font": [
          "Noto Sans Regular"
        ],
        "text-field": "{name}",
        "text-size": 13,
        "text-max-width": 6
      },
      "paint": {
        "text-color": "#777777",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1.5
      }
    }
  ]
}